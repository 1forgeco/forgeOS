{
  "name": "forgeos-agent-studio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "vite",
    "dev:api": "wrangler dev --local --port 8787 --persist-to .wrangler/state",
    "build": "tsc -b && node scripts/clean-build.mjs && vite build && vite build --ssr worker/index.ts --outDir dist/server",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply forgeos-local --local --persist-to .wrangler/state",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "@xyflow/react": "^12.11.2",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260722.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "drizzle-kit": "^0.31.10",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "wrangler": "^4.113.0"
  }
}
